# --- LINE ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- 身分綁定（初次部署時留空，用 /whoami 取得後填入） ---
TEACHER_USER_ID=
STUDENT_USER_ID=

# --- 排程 ---
CRON_SECRET=
ASSIGNMENT_PUSH_TIME=07:00
REMINDER_TIME=21:00

# --- App ---
TZ=Asia/Taipei
DATABASE_URL=sqlite:////data/bot.db
PHOTO_DIR=/data/photos
LOG_LEVEL=INFO

# 未完成作業自動繼承顯示到下一天（true=開，false=關）
CARRY_OVER_UNFINISHED=true
CARRY_OVER_WINDOW_DAYS=7
